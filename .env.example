# Supabase PostgreSQL Connection String
# Get from Supabase: Project Settings → Database → Connection string (PostgreSQL tab)
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@your-host:5432/postgres

# Session secret for express-session - generate with: openssl rand -base64 32
SESSION_SECRET=your-random-secret-key-here

# Environment type (development or production)
NODE_ENV=development

# Optional: Application port (defaults to 5000)
# PORT=5000