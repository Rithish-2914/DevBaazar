{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "dist/api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/api/index.mjs"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/api/index.mjs"
    }
  ]
}
